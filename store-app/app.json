{
  "expo": {
    "name": "ALIVE Store",
    "slug": "alive-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "backgroundColor": "#f9fafb",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#ef4444",
      "resizeMode": "cover"
    },
    "android": {
      "package": "com.partner.alive",
      "versionCode": 2,
      "targetSdkVersion": 35,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ef4444"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "scheme": "alive-store",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ALIVE Store to use your location to pin your shop on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ALIVE Store to access your photos for KYC and flyer uploads.",
          "cameraPermission": "Allow ALIVE Store to use the camera for your KYC selfie."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6a63834c-7c6a-474c-a438-ca5bbfd0b32f"
      }
    }
  }
}
