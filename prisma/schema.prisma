// ALIVE Studio — unified schema
// Postgres for ops data; Upstash Redis (separate) holds session caches and rate limiting.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl removed — Neon pooler (DATABASE_URL) handles both runtime and
  // migrations. Set DATABASE_DIRECT_URL locally for npx prisma migrate dev.
}

// ─── Auth (Auth.js compatible) ───────────────────────────────────────────────

enum UserRole {
  STORE_PARTNER
  BRAND
  AGENCY
  ADMIN
  OPS
}

model User {
  id             String     @id @default(cuid())
  email          String?    @unique
  emailVerified  DateTime?
  phone          String?    @unique
  passwordHash   String?
  name           String?
  image          String?
  role           UserRole   @default(STORE_PARTNER)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  accounts       Account[]
  sessions       Session[]
  store          Store?
  brand          Brand?

  @@index([phone])
  @@index([role])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Store partners ──────────────────────────────────────────────────────────

model Store {
  id            String     @id @default(cuid())
  userId        String     @unique
  storeName     String
  ownerName     String
  whatsapp      String
  address       String?
  locality      String?
  city          String?
  pincode       String?
  lat           Float?
  lng           Float?
  gstin         String?
  referralCode  String     @unique
  referredBy    String?
  agreedAt      DateTime?
  onboardingStage String    @default("new") // new | physically_onboarded | digitally_onboarded | live
  payoutStatus    String    @default("pending_setup") // pending_setup | ready | paid | on_hold
  payoutMethod    String?   // upi | bank
  upiId           String?
  bankAccountName String?
  bankAccountNo   String?
  bankIfsc        String?
  bankName        String?
  payoutLastPaidAt DateTime?
  payoutNotes      String?
  liveAt           DateTime?   // date admin marks store as live (earning starts from here)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices       Device[]
  bills         Bill[]
  offers        StoreOffer[]
  storePayments StorePayment[]

  @@index([city])
  @@index([pincode])
  @@index([referralCode])
}

// ─── Store Payments ───────────────────────────────────────────────────────────

model StorePayment {
  id          String   @id @default(cuid())
  storeId     String
  month       String   // "2026-05" — YYYY-MM format
  amountPaise Int      @default(50000) // ₹500 in paise
  status      String   @default("pending") // pending | paid | skipped
  paidAt      DateTime?
  paidBy      String?  // admin user id or name
  payRef      String?  // UPI reference or transaction ID
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, month])
  @@index([storeId])
  @@index([month])
  @@index([status])
}

// ─── Brands ──────────────────────────────────────────────────────────────────

model Brand {
  id          String     @id @default(cuid())
  userId      String     @unique
  brandName   String
  contactName String
  email       String
  phone       String
  gstin       String?
  walletPaise BigInt     @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns   Campaign[]
}

model Campaign {
  id              String     @id @default(cuid())
  brandId         String?
  name            String
  contactName     String?
  email           String?
  phone           String?
  screens         Int        @default(1)
  months          Int        @default(1)
  startDate       DateTime
  pricePerScreen  Int
  totalAmount     Int
  paymentId       String?
  orderId         String?
  status          String     @default("upcoming") // upcoming | active | completed | cancelled
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  brand           Brand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  playEvents      PlayEvent[]

  @@index([brandId])
  @@index([status])
  @@index([email])
}

// ─── Devices (screens) ───────────────────────────────────────────────────────

enum DeviceStatus {
  PENDING
  ONLINE
  OFFLINE
}

model Device {
  id           String        @id @default(cuid())
  hardwareKey  String        @unique
  storeId      String?
  name         String
  groupName    String?       // e.g. "Mangaluru North" — for group-based scheduling
  jwtSecret    String        // per-device secret used to sign tokens
  status       DeviceStatus  @default(PENDING)
  lastSeen     DateTime?
  uptimePctD30 Float?
  claimedAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  events       PlayEvent[]
  telemetryEvents TelemetryEvent[]
  remediationTickets RemediationTicket[]

  @@index([storeId])
  @@index([groupName])
  @@index([status])
}

enum RemediationTicketStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum RemediationActionType {
  CONFIG_CHANGE
  ROLLBACK
  PATCH_TARGET
}

enum RemediationApplyMode {
  AUTO
  REQUIRES_APPROVAL
}

model RemediationTicket {
  id                 String                  @id @default(cuid())
  deviceId           String
  status             RemediationTicketStatus @default(OPEN)
  triggerType        String
  severity           String                  @default("medium")
  triggerWindowStart DateTime?
  triggerWindowEnd   DateTime?
  snapshot           Json
  createdAt          DateTime                @default(now())
  resolvedAt         DateTime?

  device             Device                  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  proposals          RemediationProposal[]

  @@index([deviceId, status, createdAt])
  @@index([status, createdAt])
}

model RemediationProposal {
  id               String               @id @default(cuid())
  ticketId         String
  rank             Int
  actionType       RemediationActionType
  title            String
  rationale        String
  proposedChange   Json
  confidence       Float
  blastRadius      String
  blastRadiusScore Int                  @default(1)
  applyMode        RemediationApplyMode
  requiresApproval Boolean              @default(false)
  approvalState    String               @default("PENDING")
  prHookState      String               @default("NOT_REQUESTED")
  createdAt        DateTime             @default(now())

  ticket           RemediationTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, rank])
  @@index([actionType, applyMode])
}

model TelemetryEvent {
  id            String   @id @default(cuid())
  route         String
  level         String   @default("error")
  errorClass    String?
  message       String
  stackHash     String?
  correlationId String
  actorType     String
  requestMeta   Json?
  createdAt     DateTime @default(now())
  deviceId      String?

  device        Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([route, createdAt])
  @@index([correlationId])
  @@index([deviceId])
}

// ─── Content + Playlists + Schedules ─────────────────────────────────────────

enum ContentType {
  IMAGE
  VIDEO
}

model Content {
  id           String         @id @default(cuid())
  name         String
  type         ContentType
  // R2 object key — full URL is built from R2_PUBLIC_BASE
  objectKey    String         @unique
  md5          String
  sizeBytes    BigInt
  durationMs   Int?           // for video; null for image (default playback duration set by playlist)
  width        Int?
  height       Int?
  uploadedById String?
  uploadedAt   DateTime       @default(now())

  items        PlaylistItem[]

  @@index([uploadedById])
}

model Playlist {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  items     PlaylistItem[]
  schedules Schedule[]
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  contentId  String
  durationMs Int      // override duration per item
  order      Int

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([playlistId, order])
  @@index([contentId])
}

enum Recurrence {
  ONCE
  DAILY
  WEEKLY
}

model Schedule {
  id          String     @id @default(cuid())
  name        String
  playlistId  String
  priority    Int        @default(0)
  // Either deviceIds OR groupName — group-based scheduling preferred at scale (Xibo pattern)
  deviceIds   String[]   @default([])
  groupName   String?
  startAt     DateTime
  endAt       DateTime
  recurrence  Recurrence @default(ONCE)
  // Optional dayparting window (HH:mm). If null, runs all hours within startAt..endAt.
  dailyStart  String?
  dailyEnd    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  playlist    Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([groupName])
  @@index([startAt, endAt])
}

// ─── Proof-of-play ───────────────────────────────────────────────────────────

model PlayEvent {
  id         String    @id @default(cuid())
  deviceId   String
  campaignId String?
  mediaId    String    // Content.id
  layoutId   String?   // Schedule.id (which schedule was active)
  startedAt  DateTime
  endedAt    DateTime
  durationMs Int
  tag        String?   // free-form: brand/campaign external ID for billing attribution
  // Tamper-evident chain (T2 — sign each row with prev hash)
  prevHash   String?
  rowHash    String?
  createdAt  DateTime  @default(now())

  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([deviceId, startedAt])
  @@index([campaignId])
  @@index([tag])
  @@index([startedAt])
}

// ─── Flyers (existing — keep in Postgres now) ────────────────────────────────

model Flyer {
  id          String   @id @default(cuid())
  storeName   String
  title       String
  description String?
  validUntil  DateTime
  // R2 object key — replaces base64 storage in Redis
  objectKey   String?
  // Legacy: keep imageBase64 nullable for migration window
  imageBase64 String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([validUntil])
}

// ─── VoiceBill — Customer purchases ─────────────────────────────────────────

model Customer {
  id        String    @id @default(cuid())
  phone     String    @unique
  name      String
  token     String    @unique  // random UUID token stored in customer's localStorage for lightweight auth
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  bills     Bill[]

  @@index([phone])
}

model Bill {
  id          String     @id @default(cuid())
  billRef     String     @unique   // human-readable "ALIVE-XXXXXX"
  storeId     String?
  storeName   String
  totalAmount Int                  // whole rupees
  payMethod   String     @default("cash")  // cash | upi | card | khata
  status      String     @default("open")  // open | paid
  customerId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  store       Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  customer    Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       BillItem[]

  @@index([customerId])
  @@index([storeId])
  @@index([billRef])
  @@index([createdAt])
}

model BillItem {
  id     String @id @default(cuid())
  billId String
  name   String
  qty    Int
  unit   String @default("pcs")
  price  Int    // per unit in rupees

  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// ─── Store Offers ─────────────────────────────────────────────────────────────

model StoreOffer {
  id          String    @id @default(cuid())
  storeId     String
  productName String
  weight      String?               // e.g. "1 kg", "500 ml", "12 pcs"
  mrp         Int                   // MRP in rupees
  offerPrice  Int                   // offer price in rupees
  validUntil  DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([active])
  @@index([validUntil])
}

// ─── Audit log (T2) ──────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}



enum ExternalSignalSource {
  market_sentiment
  competitor_activity
  infra_cost_efficiency
}

model ExternalSignal {
  id                 String               @id @default(cuid())
  source             ExternalSignalSource
  sourceId           String
  observedAt         DateTime
  expiresAt          DateTime
  category           String
  summary            String
  details            Json
  score              Float
  trendVelocity      Float
  confidence         Float
  freshness          Float
  severity           String
  recommendedActions Json
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([source, sourceId])
  @@index([source, observedAt])
  @@index([expiresAt])
}
model ContextSyncState {
  key       String   @id
  watermark DateTime
  updatedAt DateTime @updatedAt
}

model ContextDocument {
  id          String   @id @default(cuid())
  sourceType  String
  sourceId    String
  timestamp   DateTime
  actors      String[]
  serviceArea String
  summary     String
  rawRef      String
  embedding   Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([timestamp])
  @@index([serviceArea])
}
