# ─── ALIVE Studio environment ────────────────────────────────────────────────

# ─── Auth.js ────────────────────────────────────────────────────────────────
# 32+ random bytes — generate with: openssl rand -base64 32
AUTH_SECRET=
# Required in prod when behind a proxy (Vercel handles this automatically)
# AUTH_URL=https://wearealive.in

# Optional email magic-link provider for brand/admin login (SMTP)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=hello@wearealive.in

# ─── PostgreSQL (Neon recommended for Vercel) ────────────────────────────────
# Pooled connection (used by Prisma at runtime in serverless)
DATABASE_URL=postgresql://user:pass@pooler.host/db?sslmode=require
# Direct connection for migrations (Neon: same URL but with -pooler removed)
DATABASE_DIRECT_URL=postgresql://user:pass@host/db?sslmode=require

# ─── Upstash Redis (cache + rate limiting) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cloudflare R2 (media storage) ───────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=alive-media
# Public-read base URL (custom domain or pub-<account>.r2.dev)
R2_PUBLIC_BASE=https://media.wearealive.in

# ─── Razorpay (brand campaign payments) ──────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Admin password (legacy /admin endpoints) ────────────────────────────────
# Will be replaced by Auth.js role=ADMIN once auth migration is complete
ADMIN_PASSWORD=

# ─── Clerk (LEGACY — to be removed after Auth.js migration) ──────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
